#GOOGLE_APPLICATION_CREDENTIALS=dev-indexframe-vertex-sa-key.json
PROJECT_ID=dev-indexframe
BUCKET_NAME=indexframe-data
OUTPUT_GCS_URI=gs://indexframe-data
REGION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=True
GOOGLE_CLOUD_PROJECT=dev-indexframe
GOOGLE_CLOUD_LOCATION=global
VERTEX_LOCATION=global
LIVE_LOCATION=global
STORAGE_MODE=local
STAGE1_MODEL=gemini-2.5-flash
FRAME_MODEL=gemini-2.5-flash-lite
LIVE_TEXT_MODEL=gemini-2.0-flash-live-preview-04-09
ENABLE_LIVE_AGENT=true
JOB_NAME=indexframe-poc
INDEXFRAME_AI_COVER_PROMPT="Make the cover feel cinematic, premium, less template-like."
INDEXFRAME_AI_COVERS=true

# Firebase public web config for Google SSO.
# Run ./deploy_firebase.sh to create/reuse the Firebase Web App and fill FIREBASE_API_KEY/FIREBASE_APP_ID.
DISABLE_AUTH=false
FIREBASE_PROJECT_ID=dev-indexframe
FIREBASE_AUTH_DOMAIN=dev-indexframe.firebaseapp.com
FIREBASE_WEB_APP_DISPLAY_NAME="IndexFrame Web"
FIREBASE_API_KEY=<INSERT KEY>
FIREBASE_APP_ID=<INSERT KEY>

# SMTP2GO outbound email settings. Do not put SMTP_PASSWORD here.
SMTP_HOST=mail.smtp2go.com
SMTP_PORT=2525
SMTP_USERNAME=indexframe
SMTP_PASSWORD_SECRET=SMTP2GO_PASSWORD
SMTP2GO_PASSWORD=<INSERT KEY>
EMAIL_FROM=results@demo.monodromylabs.org
EMAIL_FROM_NAME="IndexFrame Results"
EMAIL_REPLY_TO=noreply@demo.monodromylabs.org
SMTP_TLS=true

MONGODB_SECRET=MONGODB_CONNSTR
MONGODB_URI=<INSERT URL>
INDEXFRAME_MONGODB_DB="indexframe"
INDEXFRAME_MONGODB_COLLECTION="image_hero_packs"

# Local-only smoke test helpers
# DISABLE_AUTH=true
# MOCK_RUN_JOB_LOCALLY=true
# DEMO_EMAIL=your-test-recipient@gmail.com
